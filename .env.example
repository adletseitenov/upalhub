NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role (secret) key — только для сервера, супабейсовский эквивалент
# service_role. Нужен supabaseAdmin() (src/lib/supabase/admin.ts) для чтения
# tasks.answer/explanation после column-level revoke (миграция
# 20260709130000). НИКОГДА не префиксовать NEXT_PUBLIC_ и не коммитить
# реальное значение — только в .env.local / Vercel env.
SUPABASE_SECRET_KEY=
LLM_PROVIDER=openrouter
LLM_MODEL=
OPENROUTER_API_KEY=
TAVILY_API_KEY=
# TTS (озвучка listening) + STT (транскрипция спикинга). Ключ должен иметь
# доступ ТОЛЬКО к Text-to-Speech и Speech-to-Text — Speech-to-Speech/Sound
# Effects/Music Generation не используются, доступ к ним не давать.
ELEVENLABS_API_KEY=
